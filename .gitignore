```text
# 忽略 Python 缓存
__pycache__/
*.pyc
*.pyo

# 忽略虚拟环境
venv/
env/

# 忽略巨型地图文件 (github不支持大于25MB的文件，因此底图无法直接上传到源代码)
*.png
*.jpg
!docs/test/maps/卡洛西亚大陆/big_map_17173.png
!docs/test/maps/卡洛西亚大陆/big_map_17173带传送图标.png
!docs/update/maps/卡洛西亚大陆/big_map_17173.png
!docs/update/maps/卡洛西亚大陆/big_map_17173带传送图标.png
!docs/update/tools/points_icon/*.png
!img/    # 但是保留 img 文件夹里的小图标

# 忽略调试生成的图片
debug_minimap.png

# 忽略 IDE 配置文件
.idea/
.vscode/
.claude/


# SIFT base-map descriptor cache (regenerated automatically on first launch)
.cache/

# 调试模式产物（仅 GMT_SIFT_DEBUG=1 时产生），不应入库
debug/

# 运行日志（崩溃日志、路线转换日志等），不应入库
logs/

# Build outputs
build/
dist/

# 对部分打包产物放行
!docs/test/**/*.pyd
!docs/update/**/*.pyd

routes/采样分析添加标注/采样分析添加标注1.json
routes_converted/采样分析添加标注1.json

# 发行脚本读取的本机私有运行时配置（含下发链接等），不应入库
runtime_config.json